# --- Required in production ---
SECRET_KEY=generate-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=yourdomain.com
DATABASE_URL=postgres://user:pass@host:5432/dbname
SITE_BASE_URL=https://yourdomain.com

# --- Email (any SMTP provider: Resend, Postmark, etc.) ---
# Leave EMAIL_HOST unset in dev to print emails to the console.
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_PROVIDER_API_KEY=re_xxxxxxxx
EMAIL_FROM_ADDRESS=BloNo Digest <hello@yourdomain.com>
ADMIN_EMAIL=you@yourdomain.com
EMAIL_POSTAL_ADDRESS=PO Box 123, Bloomington, IL 61702

# --- Optional ---
TICKETMASTER_API_KEY=
DEFAULT_REGION_SLUG=bloomington-normal
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
