{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "python manage.py collectstatic --noinput"
  },
  "deploy": {
    "startCommand": "python manage.py import_events",
    "cronSchedule": "0 9 * * *",
    "restartPolicyType": "NEVER"
  }
}
